# Database
POSTGRES_DB=hop_db
POSTGRES_USER=hop_user
POSTGRES_PASSWORD=change-this-postgres-password
POSTGRES_PORT=5432
ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=hop_db;Username=hop_user;Password=change-this-postgres-password

# Backend
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://localhost:5000
API_PORT=5000
JWT_SECRET=change-this-jwt-secret-at-least-32-characters
Jwt__Key=change-this-jwt-secret-at-least-32-characters
Jwt__Issuer=Hop.Api
Jwt__Audience=Hop.Client
LINE_CHANNEL_SECRET=
LINE_ACCESS_TOKEN=
LINE_ENABLED=false
LINE_RETRY_ENABLED=false
LINE_RETRY_MAX_ATTEMPTS=3
LINE_RETRY_INTERVAL_MINUTES=5
Line__ChannelSecret=
Line__ChannelAccessToken=
Line__Enabled=false
LineRetry__Enabled=false
LineRetry__MaxAttempts=3
LineRetry__IntervalMinutes=5
FILE_SCAN_ENABLED=false
FILE_SCAN_PROVIDER=Placeholder
FileScan__Enabled=false
FileScan__Provider=Placeholder
APPROVAL_ESCALATION_ENABLED=false
APPROVAL_ESCALATION_INTERVAL_MINUTES=30
ApprovalEscalation__Enabled=false
ApprovalEscalation__IntervalMinutes=30
Hospital__Name=โรงพยาบาลนาหมื่น
STORAGE_ROOT_PATH=./storage
Storage__RootPath=./storage
LEAVE_ATTACHMENT_MAX_FILE_SIZE_MB=5
LeaveAttachments__MaxFileSizeMb=5
LEAVE_ATTACHMENT_ALLOWED_EXTENSIONS=.pdf,.jpg,.jpeg,.png
LeaveAttachments__AllowedExtensions=.pdf,.jpg,.jpeg,.png
REFRESH_TOKEN_REUSE_DETECTION_ENABLED=true
RefreshToken__ReuseDetectionEnabled=true
LOGIN_RATE_LIMIT_ENABLED=true
LOGIN_RATE_LIMIT_MAX_FAILED_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_MINUTES=15
LOGIN_RATE_LIMIT_LOCKOUT_MINUTES=15
