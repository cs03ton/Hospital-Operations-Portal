# Database
POSTGRES_DB=hop_db
POSTGRES_USER=hop_user
POSTGRES_PASSWORD=change-this-postgres-password
POSTGRES_PORT=5432
ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=hop_db;Username=hop_user;Password=change-this-postgres-password

# Backend
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://localhost:5000
API_PORT=5000
JWT_SECRET=change-this-jwt-secret-at-least-32-characters
Jwt__Key=change-this-jwt-secret-at-least-32-characters
Jwt__Issuer=Hop.Api
Jwt__Audience=Hop.Client
LINE_CHANNEL_SECRET=
LINE_ACCESS_TOKEN=
Line__ChannelSecret=
Line__ChannelAccessToken=
STORAGE_ROOT_PATH=./storage
Storage__RootPath=./storage
LEAVE_ATTACHMENT_MAX_FILE_SIZE_MB=5
LeaveAttachments__MaxFileSizeMb=5
LEAVE_ATTACHMENT_ALLOWED_EXTENSIONS=.pdf,.jpg,.jpeg,.png
LeaveAttachments__AllowedExtensions=.pdf,.jpg,.jpeg,.png
REFRESH_TOKEN_REUSE_DETECTION_ENABLED=true
RefreshToken__ReuseDetectionEnabled=true
AUDIT_LOG_RETENTION_DAYS=365
AuditLog__RetentionDays=365

# Frontend
FRONTEND_PORT=5173
VITE_API_URL=http://localhost:5000
VITE_API_BASE_URL=http://localhost:5000
VITE_MAX_UPLOAD_SIZE_MB=5
VITE_APP_NAME=Hospital Operations Portal
VITE_HOSPITAL_NAME=โรงพยาบาลนาหมื่น

# Gateway
NGINX_PORT=8080
