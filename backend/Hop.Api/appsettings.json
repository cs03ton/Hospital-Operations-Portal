{
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "Database": {
    "SeedOnStartup": false
  },
  "Seed": {
    "CreateDefaultAdmin": false,
    "AdminUsername": "",
    "AdminPassword": "",
    "AdminFullName": "",
    "AdminEmployeeCode": ""
  },
  "Jwt": {
    "Key": "",
    "Issuer": "Hop.Api",
    "Audience": "Hop.Client"
  },
  "Line": {
    "Enabled": false,
    "ChannelId": "",
    "AccessToken": "",
    "ChannelAccessToken": "",
    "ChannelSecret": "",
    "WebhookUrl": "",
    "PublicAppUrl": "",
    "PublicFileBaseUrl": "",
    "TestUserId": ""
  },
  "LineRetry": {
    "Enabled": false,
    "MaxAttempts": 3,
    "IntervalMinutes": 5
  },
  "FileScan": {
    "Enabled": false,
    "Provider": "Placeholder",
    "FailClosed": true
  },
  "ClamAv": {
    "ConnectionType": "Tcp",
    "Host": "localhost",
    "Port": 3310,
    "SocketPath": "/var/run/clamav/clamd.ctl",
    "TimeoutMs": 5000
  },
  "ApprovalEscalation": {
    "Enabled": false,
    "IntervalMinutes": 30
  },
  "Hospital": {
    "Name": ""
  },
  "Storage": {
    "RootPath": "",
    "PublicBaseUrl": "",
    "Announcements": {
      "MaxImageSizeBytes": 10485760,
      "MaxAttachmentSizeBytes": 10485760,
      "AllowedImageExtensions": [ ".jpg", ".jpeg", ".png", ".webp" ],
      "AllowedAttachmentExtensions": [ ".pdf", ".doc", ".docx", ".xls", ".xlsx", ".ppt", ".pptx", ".zip" ],
      "ThumbnailMaxWidth": 400,
      "ThumbnailMaxHeight": 225,
      "MediumMaxSize": 800,
      "LargeMaxSize": 1600,
      "MaximumWidth": 8000,
      "MaximumHeight": 8000,
      "MaximumPixelCount": 40000000
    }
  },
  "LeavePdf": {
    "TemplateConfigPath": "",
    "FontPath": "",
    "FontFamily": "TH SarabunPSK",
    "FontSize": 16,
    "LineHeight": 1.2
  },
  "LeaveAttachments": {
    "MaxFileSizeMb": 5,
    "AllowedExtensions": ".pdf,.jpg,.jpeg,.png,.webp"
  },
  "RefreshToken": {
    "ReuseDetectionEnabled": true
  },
  "Auth": {
    "TokenStorageMode": "LocalStorage",
    "Cookie": {
      "Secure": false,
      "SameSite": "Lax",
      "Domain": "",
      "RefreshTokenName": "hop_refresh_token",
      "CsrfEnabled": true,
      "CsrfTokenName": "hop_csrf_token",
      "CsrfHeaderName": "X-CSRF-TOKEN"
    }
  },
  "LoginRateLimit": {
    "Enabled": true,
    "MaxFailedAttempts": 5,
    "WindowMinutes": 15,
    "LockoutMinutes": 15
  },
  "PasswordPolicy": {
    "MinimumLength": 8,
    "RequireUppercase": true,
    "RequireLowercase": true,
    "RequireDigit": true,
    "RequireSpecialCharacter": true,
    "PasswordHistoryCount": 0,
    "ExpireDays": 0,
    "DisallowUsername": true
  },
  "AuditLog": {
    "RetentionDays": 365
  },
  "Cors": {
    "AllowCredentials": false,
    "AllowedOrigins": [
      "http://localhost:5173",
      "http://127.0.0.1:5173",
      "http://localhost:8080"
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
