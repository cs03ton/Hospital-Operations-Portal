{
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "Jwt": {
    "Key": "",
    "Issuer": "Hop.Api",
    "Audience": "Hop.Client"
  },
  "Line": {
    "Enabled": false,
    "ChannelAccessToken": "",
    "ChannelSecret": ""
  },
  "LineRetry": {
    "Enabled": false,
    "MaxAttempts": 3,
    "IntervalMinutes": 5
  },
  "FileScan": {
    "Enabled": false,
    "Provider": "Placeholder"
  },
  "ApprovalEscalation": {
    "Enabled": false,
    "IntervalMinutes": 30
  },
  "Hospital": {
    "Name": ""
  },
  "Storage": {
    "RootPath": ""
  },
  "LeaveAttachments": {
    "MaxFileSizeMb": 5,
    "AllowedExtensions": ".pdf,.jpg,.jpeg,.png"
  },
  "RefreshToken": {
    "ReuseDetectionEnabled": true
  },
  "LoginRateLimit": {
    "Enabled": true,
    "MaxFailedAttempts": 5,
    "WindowMinutes": 15,
    "LockoutMinutes": 15
  },
  "AuditLog": {
    "RetentionDays": 365
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173",
      "http://127.0.0.1:5173",
      "http://localhost:8080"
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
