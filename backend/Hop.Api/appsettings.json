{
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "Jwt": {
    "Key": "",
    "Issuer": "Hop.Api",
    "Audience": "Hop.Client"
  },
  "Line": {
    "ChannelAccessToken": "",
    "ChannelSecret": ""
  },
  "Storage": {
    "RootPath": ""
  },
  "LeaveAttachments": {
    "MaxFileSizeMb": 5,
    "AllowedExtensions": ".pdf,.jpg,.jpeg,.png"
  },
  "RefreshToken": {
    "ReuseDetectionEnabled": true
  },
  "AuditLog": {
    "RetentionDays": 365
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173",
      "http://127.0.0.1:5173",
      "http://localhost:8080"
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
