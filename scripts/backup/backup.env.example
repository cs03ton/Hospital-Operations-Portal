# HOP Backup/Restore environment example
# Copy to /etc/hop/backup.env or set BACKUP_ENV_FILE=/path/to/backup.env
# Do not commit real passwords or tokens.

BACKUP_MODE=host
BACKUP_ROOT=/opt/hop/backups
BACKUP_RETENTION_DAYS=7

# Optional: when cron/systemd runs backup as root, make generated files readable by the HOP API service user.
# Recommended for bare-metal production where hop-api runs as user/group hop.
BACKUP_OWNER=hop:hop
BACKUP_DIR_MODE=750
BACKUP_FILE_MODE=640

DB_HOST=localhost
DB_PORT=5432
DB_NAME=hop_db
DB_USER=hop_user
# Recommended: use PGPASSFILE or inject DB_PASSWORD from a secure environment file.
# DB_PASSWORD=

# Docker mode only
POSTGRES_CONTAINER=hop-prod-postgres
STORAGE_DOCKER_VOLUME=hop_prod_storage

# Bare-metal uploads/storage path.
# For HOP bare-metal deployment this is usually /opt/hop/uploads.
UPLOADS_PATH=/opt/hop/uploads

# Optional shared log file. The script creates this directory when possible.
# If this path is not writable, the script falls back to BACKUP_ROOT/logs/backup_*.log.
LOG_FILE=/var/log/hop/backup.log
LOCK_FILE=/var/lock/hop-backup.lock

# Restore automation guard. Required when using restore-hop.sh --yes.
# RESTORE_CONFIRMATION=RESTORE_HOP_DATABASE
