events {}

http {
    map $http_x_forwarded_proto $strict_transport_security {
        default "";
        https "max-age=31536000; includeSubDomains";
    }

    upstream hop_backend {
        server backend:8080;
    }

    server {
        listen 80;
        server_name hop.example.local;

        root /usr/share/nginx/html;
        index index.html;

        client_max_body_size 20m;
        gzip on;
        gzip_types application/javascript application/json image/svg+xml text/css text/plain;

        add_header X-Frame-Options "DENY" always;
        add_header X-Content-Type-Options "nosniff" always;
        add_header Referrer-Policy "strict-origin-when-cross-origin" always;
        add_header Permissions-Policy "camera=(), microphone=(), geolocation=()" always;
        add_header Strict-Transport-Security $strict_transport_security always;

        location /api/ {
            proxy_pass http://hop_backend;
            proxy_http_version 1.1;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
            proxy_set_header X-Correlation-ID $http_x_correlation_id;
        }

        location /healthz {
            proxy_pass http://hop_backend;
            proxy_set_header Host $host;
        }

        location /health {
            proxy_pass http://hop_backend;
            proxy_set_header Host $host;
        }

        location /health/live {
            proxy_pass http://hop_backend;
            proxy_set_header Host $host;
        }

        location /health/ready {
            proxy_pass http://hop_backend;
            proxy_set_header Host $host;
        }

        location / {
            try_files $uri $uri/ /index.html;
        }
    }
}
