# ---------------------------------------------------------------------------
# Hospital Operations Portal (HOP)
# Keep source, docs, migrations, schema, seed, and example config in Git.
# Keep local secrets, runtime data, generated output, and QA artifacts out.
# ---------------------------------------------------------------------------

# Environment / secrets
.env
.env.*
!.env.example
!.env.production.example
!**/.env.example
appsettings.Production.json
**/appsettings.Production.json
*.local
*.secret
*.secrets

# Logs / runtime process files
*.log
*.err.log
*.pid
logs/
**/logs/

# OS / editors
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
.vscode/
.idea/

# Visual Studio / .NET
.vs/
**/.vs/
bin/
obj/
**/bin/
**/obj/
*.user
*.rsuser
*.suo
*.userosscache
*.sln.docstates
TestResults/
**/TestResults/
coverage/
**/coverage/
*.coverage
*.coveragexml
*.trx

# .NET generated publish / local build copies
publish/
**/publish/
artifacts/
**/artifacts/

# Node / React / Vite
node_modules/
**/node_modules/
dist/
**/dist/
build/
**/build/
.vite/
**/.vite/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Playwright / frontend test artifacts
playwright-report/
**/playwright-report/
test-results/
**/test-results/
blob-report/
**/blob-report/
frontend/playwright/.cache/
tests/e2e/screenshots/screenshot-users.json
frontend/e2e/screenshots/screenshot-users.json
tests/screenshots/config/screenshot-users.json
docs/manuals/assets/screenshots/.capture-records.jsonl

# QA browser automation artifacts
docs/qa/chrome-profile/
docs/qa/screenshots/
docs/qa/downloads/
docs/qa/*.log
docs/qa/*.err.log
docs/qa/*.pid
docs/qa/*.json
docs/qa/*.pdf
docs/qa/*.png
docs/qa/*.txt
!docs/qa/*.md

# Runtime uploads / generated storage
storage/*
!storage/.gitkeep
!storage/templates/
!storage/templates/**
backend/Hop.Api/storage/
backend/Hop.Api/wwwroot/uploads/
backend/Hop.Api/uploads/
uploads/
**/uploads/

# Database dumps / backups / local volume data
*.backup
*.bak
*.dump
*.sql.gz
*.sql.zip
*.tar
*.tar.gz
*.zip
backups/
database/backup/*
!database/backup/.gitkeep
postgres-data/
pgdata/
docker-data/
volumes/

# Docker local state
.docker/
docker-compose.override.yml

# Temporary files
tmp/
temp/
*.tmp
*.temp
*.cache
*.pma
